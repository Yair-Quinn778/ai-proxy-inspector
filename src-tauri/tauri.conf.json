{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri-v2-docs/main/schema.json",
  "productName": "AI Proxy Inspector",
  "version": "1.0.0",
  "identifier": "com.ai-proxy-inspector.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "AI代理检测器",
        "width": 1280,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 680,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
